<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".SettingsActivity">

    <RelativeLayout
        android:id="@+id/rl_settings_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="37dp"
            android:layout_height="38dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="返回"
            android:src="?attr/homeAsUpIndicator" />

        <TextView
            android:id="@+id/tv_settings_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="设置"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_centerInParent="true" />

    </RelativeLayout>

    <ScrollView
        android:id="@+id/sv_settings_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/rl_settings_header"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        
        <LinearLayout
            android:id="@+id/ll_settings_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <!-- API地址输入框 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="API地址"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />
            <EditText
                android:id="@+id/et_api_url"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="请输入API地址"
                android:inputType="textUri"
                android:padding="12dp"
                android:background="@android:drawable/editbox_background_normal" />
        </LinearLayout>

        <!-- API密钥输入框 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="API密钥"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <EditText
                    android:id="@+id/et_api_key"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="请输入API密钥"
                    android:inputType="textPassword"
                    android:padding="12dp"
                    android:background="@android:drawable/editbox_background_normal" />
                <ImageButton
                    android:id="@+id/btn_toggle_api_key"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="显示/隐藏密钥"
                    android:src="@drawable/ic_visibility_off" />
            </LinearLayout>
        </LinearLayout>

        <!-- 设备标识符输入框 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="设备标识符"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />
            <EditText
                android:id="@+id/et_device_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="请输入设备标识符"
                android:inputType="text"
                android:padding="12dp"
                android:background="@android:drawable/editbox_background_normal" />
        </LinearLayout>

        <!-- 显示名称输入框 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="显示名称"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />
            <EditText
                android:id="@+id/et_display_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="请输入显示名称"
                android:inputType="text"
                android:padding="12dp"
                android:background="@android:drawable/editbox_background_normal" />
        </LinearLayout>

        <!-- 检查间隔输入框 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="检查间隔（秒）"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />
            <EditText
                android:id="@+id/et_check_interval"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="请输入检查间隔"
                android:inputType="number"
                android:padding="12dp"
                android:background="@android:drawable/editbox_background_normal" />
        </LinearLayout>

        <!-- 隐藏系统应用开关 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="隐藏系统应用"
                android:textSize="16sp" />
            <Switch
                android:id="@+id/sw_hide_system_apps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true" />
        </LinearLayout>

        <!-- 权限管理 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="权限管理"
                android:textSize="16sp"
                android:layout_marginBottom="12dp" />
            
            <!-- 自启动权限 -->
            <Button
                android:id="@+id/btn_auto_start"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="自启动权限"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"
                android:backgroundTint="?attr/colorSecondary"
                android:textColor="@android:color/white" />
            
            <!-- 忽略电池优化权限 -->
            <Button
                android:id="@+id/btn_battery_optimization"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="忽略电池优化"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"
                android:backgroundTint="?attr/colorSecondary"
                android:textColor="@android:color/white" />
            
            <!-- 无障碍权限 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/tv_accessibility"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="无障碍权限: 未开启"
                    android:textSize="14sp" />
                <Switch
                    android:id="@+id/sw_accessibility"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false" />
            </LinearLayout>
            
            <!-- 常驻通知权限 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/tv_notification"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="常驻通知权限: 未开启"
                    android:textSize="14sp" />
                <Switch
                    android:id="@+id/sw_notification"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false" />
            </LinearLayout>
        </LinearLayout>

        <!-- 保存按钮 -->
        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="保存"
            android:textSize="16sp"
            android:backgroundTint="?attr/colorPrimary"
            android:textColor="@android:color/white"
            android:padding="12dp"
            android:layout_marginBottom="24dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>